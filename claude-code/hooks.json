{
  "description": "AgentMem — Redis HNSW persistent memory for Claude Code (v1.1.0)",
  "hooks": {
    "SessionStart": [{
      "matcher": "startup|clear|compact",
      "hooks": [
        {"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/register-env.sh",   "timeout": 10},
        {"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/register-tools.sh", "timeout": 10}
      ]
    }],
    "UserPromptSubmit": [{
      "hooks": [{"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/recall.sh", "timeout": 10}]
    }],
    "PostToolUse": [{
      "hooks": [{"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/compact.sh", "timeout": 5}]
    }],
    "PostToolUseFailure": [{
      "hooks": [{"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/failure.sh", "timeout": 5}]
    }],
    "PreCompact": [{
      "hooks": [{"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/precompact.sh", "timeout": 8}]
    }],
    "Stop": [{
      "hooks": [{"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/store.sh", "timeout": 30}]
    }],
    "SubagentStop": [{
      "hooks": [{"type": "command", "command": "/Users/jace/code/agentmem/claude-code/hooks/store.sh", "timeout": 15}]
    }]
  }
}
