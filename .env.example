# ZAI API key for GLM-4-flash summarization (optional)
# Get a key at https://open.bigmodel.cn/
# Without a key, long turns are truncated to 180 chars instead of summarized.
ZAI_API_KEY=your-key-here

# MemOS API key — only needed if keeping memos-cloud as fallback
# MEMOS_API_KEY=your-key-here
