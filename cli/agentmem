#!/usr/bin/env python3
"""
agentmem — Developer's Memory CLI

Memory commands (query the running service):
  agentmem                       → overview + commands
  agentmem recall <QUERY>        → top-K memories for a query
  agentmem store <TEXT>          → store a fact/memory
  agentmem procedures <QUERY>    → recall stored procedures
  agentmem graph <ENTITY>        → knowledge-graph neighborhood
  agentmem stats                 → service stats
  agentmem health                → up/down

Service commands (manage the service itself):
  agentmem start [--host H] [--port P] [--dev]
  agentmem connect [AGENT] [--all] [--dry-run] [--force]
  agentmem doctor
  agentmem demo
  agentmem version

Backend: http://localhost:18800 (override via AGENTMEM_URL).
"""
from __future__ import annotations

import asyncio
import json
import os
import sys
import urllib.request
import urllib.error
from typing import Any, Optional

BASE = os.environ.get("AGENTMEM_URL", "http://localhost:18800").rstrip("/")
TIMEOUT = float(os.environ.get("AGENTMEM_TIMEOUT", "10"))


def _req(method: str, path: str, body: Optional[dict] = None) -> tuple[int, Any]:
    url = f"{BASE}{path}"
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    if data is not None:
        req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=TIMEOUT) as r:
            raw = r.read().decode("utf-8", errors="replace")
            try:
                return r.status, json.loads(raw)
            except json.JSONDecodeError:
                return r.status, raw
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode(errors="replace")[:500]
    except Exception as e:
        return 0, str(e)


def die(msg: str, code: int = 1) -> None:
    print(f"agentmem: {msg}", file=sys.stderr); sys.exit(code)


def cmd_root() -> None:
    print("agentmem — Developer's Memory (port 18800)\n")
    print("Memory commands (query the running service):")
    print("  agentmem recall <query>       top relevant memories for a query")
    print("  agentmem store <text>         store a new fact / memory")
    print("  agentmem procedures <query>   recall stored procedures (how-to memory)")
    print("  agentmem graph <entity>       knowledge-graph neighborhood")
    print("  agentmem stats                memory stats / counts")
    print("  agentmem health               check service health")
    print()
    print("Service commands:")
    print("  agentmem start [--host H] [--port P] [--dev] [--no-auto]   start the server")
    print("  agentmem connect [agent] [--all] [--force]                 wire into AI agents")
    print("  (auto-connect is default on start; use --no-auto to skip)")
    print("  agentmem doctor                                            diagnose issues")
    print("  agentmem migrate-embeddings --provider <name>  switch embedding provider")
    print("  agentmem demo                                  quick demo")
    print("  agentmem version                               print version")
    print()
    print("Tip: stored memories survive across all chats.")


# ── Memory commands ───────────────────────────────────────────────────────────

def cmd_recall(args: list[str]) -> None:
    if not args: die("usage: agentmem recall <query>")
    q = " ".join(args)
    status, body = _req("POST", "/recall", {
        "query": q, "memory_limit_number": 6,
        "include_tools": False, "include_procedures": True,
    })
    if status != 200: die(f"recall failed ({status}): {body}")
    ctx = (body or {}).get("prependContext") or ""
    if ctx.strip():
        print(ctx)
    else:
        print("(no relevant memories)")


def cmd_store(args: list[str]) -> None:
    if not args: die("usage: agentmem store <text>")
    text = " ".join(args)
    status, body = _req("POST", "/store", {"content": text, "type": "fact"})
    if status != 200: die(f"store failed ({status}): {body}")
    print(json.dumps(body, indent=2, ensure_ascii=False))


def cmd_procedures(args: list[str]) -> None:
    if not args: die("usage: agentmem procedures <query>")
    q = " ".join(args)
    status, body = _req("POST", "/recall-procedures", {"query": q, "limit": 5})
    if status != 200: die(f"procedures failed ({status}): {body}")
    procs = (body or {}).get("procedures") or body.get("results") or []
    if not procs:
        print("(no matching procedures)"); return
    for p in procs[:5]:
        name = p.get("name") or p.get("title") or "(untitled)"
        desc = p.get("description") or p.get("content") or ""
        print(f"  • {name}\n    {desc[:200]}")


def cmd_graph(args: list[str]) -> None:
    if not args: die("usage: agentmem graph <entity>")
    ent = " ".join(args)
    import urllib.parse
    status, body = _req("GET", f"/graph/{urllib.parse.quote(ent, safe='')}")
    if status != 200: die(f"graph failed ({status}): {body}")
    print(json.dumps(body, indent=2, ensure_ascii=False))


def cmd_stats() -> None:
    status, body = _req("GET", "/stats")
    if status != 200: die(f"stats failed ({status}): {body}")
    print(json.dumps(body, indent=2, ensure_ascii=False))


def cmd_health() -> None:
    status, body = _req("GET", "/health")
    if status == 200:
        print(f"OK  {json.dumps(body, ensure_ascii=False)}")
    else:
        print(f"DOWN ({status}): {body}"); sys.exit(1)


# ── Service commands ──────────────────────────────────────────────────────────

def cmd_start(args: list[str]) -> None:
    import uvicorn
    host = "0.0.0.0"
    port = 18800
    dev = False
    no_auto = False
    i = 0
    while i < len(args):
        if args[i] == "--host" and i + 1 < len(args):
            host = args[i + 1]; i += 2
        elif args[i] == "--port" and i + 1 < len(args):
            port = int(args[i + 1]); i += 2
        elif args[i] == "--dev":
            dev = True; i += 1
        elif args[i] == "--no-auto":
            no_auto = True; i += 1
        else:
            i += 1

    host = os.getenv("AGENTMEM_HOST", host)
    port = int(os.getenv("AGENTMEM_PORT", str(port)))

    # Auto-connect detected agents unless --no-auto
    if not no_auto:
        import threading
        def _auto_connect():
            import time
            # Wait for service to be ready
            for _ in range(40):
                try:
                    s, _ = _req("GET", "/health")
                    if s == 200:
                        break
                except Exception:
                    pass
                time.sleep(1)
            else:
                return
            try:
                _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
                if _project_root not in sys.path:
                    sys.path.insert(0, _project_root)
                from connect import run_connect
                run_connect(all_agents=True)
            except Exception as e:
                print(f"[agentmem] auto-connect failed: {e}", file=sys.stderr)
        t = threading.Thread(target=_auto_connect, daemon=True)
        t.start()
    else:
        print("  (--no-auto: skipping agent auto-connect)")

    print(f"🧠 AgentMem — starting on {host}:{port}")
    uvicorn.run("main:app", host=host, port=port, reload=dev)


def cmd_connect(args: list[str]) -> None:
    from connect import run_connect

    agent_name = ""
    dry_run = False
    force = False
    all_agents = False
    i = 0
    while i < len(args):
        if args[i] == "--all":
            all_agents = True; i += 1
        elif args[i] == "--dry-run":
            dry_run = True; i += 1
        elif args[i] == "--force":
            force = True; i += 1
        elif not args[i].startswith("-"):
            agent_name = args[i]; i += 1
        else:
            i += 1

    run_connect(agent_name=agent_name, dry_run=dry_run, force=force, all_agents=all_agents)


def cmd_doctor(args: list[str]) -> None:
    print("\n🩺 AgentMem Doctor\n")

    issues = []

    redis_url = os.getenv("REDIS_URL", "redis://localhost:6379")
    print(f"  Redis URL: {redis_url}")
    try:
        import redis.asyncio as aioredis
        async def _check():
            r = aioredis.from_url(redis_url, decode_responses=True)
            await r.ping()
            info = await r.info("server")
            ver = info.get("redis_version", "?")
            print(f"  Redis version: {ver}")
            try:
                card = await r.execute_command("VCARD", "mem:episodes")
                print("  ✓ Redis vectorset support detected")
            except Exception:
                print("  ⚠ Redis vectorset NOT available (need Redis 8+)")
                issues.append("Redis 8+ with vectorset support required")
            await r.aclose()
        asyncio.run(_check())
    except Exception as e:
        print(f"  ❌ Redis connection failed: {e}")
        issues.append(f"Redis unreachable: {e}")

    print()
    # Add project root to path so core module is importable
    _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if _project_root not in sys.path:
        sys.path.insert(0, _project_root)
    try:
        from core import embedder
        print("  ✓ Embedder module loaded")
    except Exception as e:
        print(f"  ❌ Embedder module: {e}")
        issues.append(f"Embedder: {e}")

    try:
        import httpx
        print("  ✓ httpx (hooks dependency)")
    except ImportError:
        print("  ⚠ httpx not installed (hooks won't work)")
        issues.append("pip install httpx")

    try:
        from ulid import ULID
        print("  ✓ ulid")
    except ImportError:
        print("  ⚠ ulid not installed")
        issues.append("pip install ulid-py")

    print()
    agents = []
    if os.path.isdir(os.path.expanduser("~/.claude")):
        agents.append("claude-code")
    if os.path.isdir(os.path.expanduser("~/.codex")):
        agents.append("codex")
    if os.path.isdir(os.path.expanduser("~/.cursor")):
        agents.append("cursor")
    if os.path.isfile(os.path.expanduser("~/.gemini/settings.json")):
        agents.append("gemini-cli")

    if agents:
        print(f"  Detected agents: {', '.join(agents)}")
    else:
        print("  No supported agents detected")

    print()
    if issues:
        print(f"  ❌ {len(issues)} issue(s) found:")
        for i, issue in enumerate(issues, 1):
            print(f"     {i}. {issue}")
    else:
        print("  ✓ All checks passed!")

    print()


