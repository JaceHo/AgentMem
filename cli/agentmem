# ── Main ──────────────────────────────────────────────────────────────────────

SERVICE_COMMANDS = {"start", "connect", "doctor", "demo", "version", "migrate-embeddings"}
MEMORY_COMMANDS = {"recall", "store", "procedures", "graph", "stats", "health"}


def main(argv: list[str]) -> None:
    if not argv: cmd_root(); return
    cmd, rest = argv[0], argv[1:]
    if cmd in ("-h", "--help", "help"): cmd_root(); return

    if cmd == "recall":     cmd_recall(rest);     return
    if cmd == "store":      cmd_store(rest);      return
    if cmd == "procedures": cmd_procedures(rest); return
    if cmd == "graph":      cmd_graph(rest);      return
    if cmd == "stats":      cmd_stats();          return
    if cmd == "health":     cmd_health();         return

    if cmd == "start":      cmd_start(rest);      return
    if cmd == "connect":    cmd_connect(rest);    return
    if cmd == "doctor":     cmd_doctor(rest);     return
    if cmd == "demo":       cmd_demo(rest);       return
    if cmd == "version":    cmd_version(rest);    return
    if cmd == "migrate-embeddings": cmd_migrate_embeddings(rest); return

    die(f"unknown command '{cmd}' (try: agentmem help)")


if __name__ == "__main__":
    try:
        main(sys.argv[1:])
    except KeyboardInterrupt:
        sys.exit(130)
