def cmd_migrate_embeddings(args: list[str]) -> None:
    """Re-embed all vectors using a different embedding provider.

    Usage: agentmem migrate-embeddings [--provider PROVIDER] [--dry-run]

    This reads all entries from each vectorset, re-embeds the content text
    with the new provider, and rebuilds the vectorsets. Required when
    switching from local (384-dim) to ollama (768-dim) or vice versa.
    """
    _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if _project_root not in sys.path:
        sys.path.insert(0, _project_root)

    provider_name = None
    dry_run = False
    i = 0
    while i < len(args):
        if args[i] == "--provider" and i + 1 < len(args):
            provider_name = args[i + 1]; i += 2
        elif args[i] == "--dry-run":
            dry_run = True; i += 1
        else:
            i += 1

    if not provider_name:
        print("Usage: agentmem migrate-embeddings --provider <local|ollama|openai|gemini> [--dry-run]")
        print()
        print("Providers:")
        print("  local   — sentence-transformers MiniLM (384-dim, no API key)")
        print("  ollama  — local Ollama nomic-embed-text (768-dim, needs model)")
        print("  openai  — OpenAI text-embedding-3-small (1536-dim, needs key)")
        print("  gemini  — Google Gemini embedding (768-dim, needs key)")
        return

    import numpy as np
    import redis.asyncio as aioredis
    from core import embedder, store as mem_store

    async def _migrate():
        # Force the new provider
        embedder._reset_provider(provider_name)
        new_dims = embedder.DIMS
        print(f"\n🔄 Migrating embeddings to provider: {provider_name} ({new_dims}-dim)\n")

        r = await mem_store.get_client()

        # Check current state
        for vset_name, vset_key in [
            ("Episodes", mem_store.EPISODE_KEY),
            ("Facts", mem_store.FACT_KEY),
            ("Procedures", mem_store.PROC_KEY),
        ]:
            try:
                card = await r.execute_command("VCARD", vset_key)
                info = await r.execute_command("VINFO", vset_key)
                info_dict = dict(zip(info[::2], info[1::2]))
                old_dims = int(info_dict.get(b"vector-dim", info_dict.get("vector-dim", 0)))
                print(f"  {vset_name}: {max(0, int(card or 0) - 1)} entries, current dims={old_dims}")
            except Exception:
                print(f"  {vset_name}: empty or not found")

        if dry_run:
            print("\n  (dry-run, not making changes)")
            await r.aclose()
            return

        # Phase 1: Read ALL entries from all vectorsets (before changing dims)
        all_data = {}
        for vset_name, vset_key in [
            ("Episodes", mem_store.EPISODE_KEY),
            ("Facts", mem_store.FACT_KEY),
            ("Procedures", mem_store.PROC_KEY),
        ]:
            try:
                card = await r.execute_command("VCARD", vset_key)
                if not card or int(card) <= 1:
                    print(f"\n  {vset_name}: nothing to migrate")
                    all_data[vset_name] = {"key": vset_key, "entries": []}
                    continue
            except Exception:
                print(f"\n  {vset_name}: skipping (not found)")
                all_data[vset_name] = {"key": vset_key, "entries": []}
                continue

            # Read all entries using zero vector matching current dims
            # Get actual dims from VINFO (handles mixed-dim state after partial migration)
            try:
                info = await r.execute_command("VINFO", vset_key)
                info_dict = dict(zip(info[::2], info[1::2]))
                old_dims = int(info_dict.get(b"vector-dim", info_dict.get("vector-dim", mem_store.DIMS)))
            except Exception:
                old_dims = mem_store.DIMS
            seed = np.zeros(old_dims, dtype=np.float32)
            results = await r.execute_command(
                "VSIM", vset_key, "FP32", mem_store._blob(seed),
                "COUNT", min(int(card), 5000), "WITHSCORES", "WITHATTRIBS"
            )

            entries = []
            i = 0
            while i + 2 < len(results):
                elem = results[i]; raw = results[i + 2]
                i += 3
                elem_str = elem.decode() if isinstance(elem, bytes) else elem
                if elem_str == "__seed__":
                    continue
                try:
                    attrs = json.loads(raw.decode() if isinstance(raw, bytes) else raw)
                except Exception:
                    continue
                if attrs.get("_seed"):
                    continue
                entries.append({"uid": elem_str, "attrs": attrs})

            all_data[vset_name] = {"key": vset_key, "entries": entries}
            print(f"\n  {vset_name}: read {len(entries)} entries")

        # Phase 2: Re-embed all content with new provider
        for vset_name, data in all_data.items():
            entries = data["entries"]
            if not entries:
                continue

            print(f"\n  {vset_name}: re-embedding {len(entries)} entries...")
            texts = []
            for e in entries:
                content = e["attrs"].get("content", "") or e["attrs"].get("task", "")
                texts.append(content)

            new_vecs = []
            batch_size = 32
            for j in range(0, len(texts), batch_size):
                batch = texts[j:j+batch_size]
                vecs = embedder.encode_batch(batch)
                new_vecs.extend(vecs)
                print(f"    embedded {min(j+batch_size, len(texts))}/{len(texts)}")

            data["vectors"] = new_vecs

        # Phase 3: Delete old vectorsets and rebuild with new dims
        mem_store.DIMS = new_dims
        for vset_name, data in all_data.items():
            vset_key = data["key"]
            entries = data["entries"]
            vecs = data.get("vectors", [])

            if not entries:
                continue

            # Delete old vectorset
            await r.delete(vset_key)

            # Re-create with new seed
            seed = np.zeros(new_dims, dtype=np.float32)
            seed_attr = json.dumps({"_seed": True, "content": "",
                                    "language": "en", "domain": "general",
                                    "access_count": 0, "ts": 0,
                                    "importance": 0.0, "superseded_by": ""})
            await r.execute_command("VADD", vset_key, "FP32", mem_store._blob(seed),
                                    "__seed__", "SETATTR", seed_attr)

            # Re-add all entries with new embeddings
            for e, vec in zip(entries, vecs):
                await r.execute_command("VADD", vset_key, "FP32",
                                        mem_store._blob(vec), e["uid"],
                                        "SETATTR", json.dumps(e["attrs"]))

            print(f"    ✓ {vset_name} migrated ({len(entries)} entries, {new_dims}-dim)")

        # Also update tool capability vectorset
        try:
            from core.capability import ensure_tool_index
            await r.delete(mem_store.TOOL_KEY)
            await ensure_tool_index(r, new_dims)
            print(f"\n  Tools: re-indexed with {new_dims}-dim")
        except Exception as e:
            print(f"\n  Tools: skip ({e})")

        await r.aclose()
        print(f"\n  ✓ Migration complete! Provider: {provider_name}, dims: {new_dims}")
        print(f"  Restart the server to apply: ./agentmem.sh restart --force")

    asyncio.run(_migrate())


